APP_NAME=Fretado API
APP_ENV=development
SECRET_KEY=sua_chave_aqui
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=postgresql://usuario:senha@localhost:5432/fretado_db
CORS_ALLOW_ORIGINS=
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|10(?:\.\d{1,3}){3}|172\.(?:1[6-9]|2\d|3[0-1])(?:\.\d{1,3}){2}|192\.168(?:\.\d{1,3}){2})(:\d+)?$
